CFLAGS=-g -O0 $CFLAGS
CXXFLAGS=-g -O0 $CXXFLAGS
--prefix=$PWD/install
--enable-debug
--enable-silent-rules
--enable-fuzzers
--disable-lto
--enable-coplugin
--enable-experimental
--enable-cypress
--with-lo-path=$HOME/git/collaboraonline/online-fuzz/engine/instdir
--with-lokit-path=$HOME/git/collaboraonline/online-fuzz/engine/include
